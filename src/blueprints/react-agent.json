{
  "id": "react-agent",
  "name": "ReAct Agent",
  "description": "Reason → act → observe loop: the LLM thinks, calls a tool, then a condition decides whether to loop back or answer.",
  "nodes": [
    {
      "id": "note-1",
      "type": "note",
      "position": { "x": 320, "y": 20 },
      "data": {
        "label": "How it works",
        "text": "ReAct: the LLM reasons about the task, calls a tool, observes the result, and repeats until the condition says it is done."
      }
    },
    {
      "id": "start-1",
      "type": "start",
      "position": { "x": 40, "y": 220 },
      "data": { "label": "Start", "inputVariables": ["question"] }
    },
    {
      "id": "llm-1",
      "type": "llm",
      "position": { "x": 300, "y": 220 },
      "data": {
        "label": "Reasoner",
        "model": "gemini-flash",
        "systemPrompt": "You are a ReAct agent. Think step by step, decide whether to call a tool, and answer when you have enough information.",
        "temperature": 0.7
      }
    },
    {
      "id": "tool-1",
      "type": "tool",
      "position": { "x": 560, "y": 220 },
      "data": {
        "label": "Search Tool",
        "toolName": "web_search",
        "description": "Search the web for up-to-date information.",
        "inputSchema": "query: str",
        "outputSchema": "result: str"
      }
    },
    {
      "id": "condition-1",
      "type": "condition",
      "position": { "x": 820, "y": 220 },
      "data": {
        "label": "Done?",
        "branches": ["needs another tool call", "final answer ready"]
      }
    },
    {
      "id": "output-1",
      "type": "output",
      "position": { "x": 1080, "y": 220 },
      "data": { "label": "Final Answer" }
    },
    {
      "id": "note-2",
      "type": "note",
      "position": { "x": 560, "y": 420 },
      "data": {
        "label": "The loop",
        "text": "The 'continue' edge feeds the tool result back to the Reasoner — this back-edge is what makes it an agent rather than a pipeline."
      }
    }
  ],
  "edges": [
    { "id": "e1", "source": "start-1", "target": "llm-1" },
    { "id": "e2", "source": "llm-1", "target": "tool-1" },
    { "id": "e3", "source": "tool-1", "target": "condition-1" },
