    {
      "id": "note-2",
      "type": "note",
      "position": { "x": 1580, "y": 480 },
      "data": {
        "label": "The re-plan loop",
        "text": "On 'gaps' the Evaluator routes back to the Planner; MAX_NODE_VISITS bounds the loop. Sim takes 'complete' on its first pass and persists the report to the Long-Term Store before returning."
      }
    }
