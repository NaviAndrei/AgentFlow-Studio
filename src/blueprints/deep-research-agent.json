{
  "id": "deep-research-agent",
  "schemaVersion": 1,
  "name": "Deep Research Agent",
  "description": "The flagship 2026 deep-agent pattern: a Planner decomposes the question, Map fans one Send per subtopic to isolated-context Subagents that research in parallel, a Synthesizer drafts the report, an Evaluator grades completeness and either re-plans on gaps or persists the report to long-term memory.",
  "category": "Research",
  "nodes": [
    {
      "id": "note-1",
      "type": "note",
      "position": { "x": 380, "y": 0 },
      "data": {
        "label": "Deep Research Agent — flagship",
        "text": "Plan → Map (Send) → Subagents (isolated context) → Join → Synthesize → Evaluate → [gaps → re-plan] or [complete → persist → output]. Showcases every Wave-2 primitive working together."
      }
    },
    {
      "id": "start-1",
      "type": "start",
      "position": { "x": 40, "y": 320 },
      "data": { "label": "Start", "inputVariables": ["question"] }
    },
    {
      "id": "planner-1",
      "type": "planner",
      "position": { "x": 280, "y": 320 },
      "data": {
        "label": "Planner",
        "decompositionPrompt": "Decompose the research question into 3-5 independent subtopics. Output them under the state key 'todos'.",
        "maxTasks": 4
      }
    },
    {
      "id": "map-1",
      "type": "map",
      "position": { "x": 540, "y": 320 },
      "data": {
        "label": "Per-Subtopic Fan-out",
        "inputExpression": "todos",
        "maxParallel": 4
      }
    },
    {
      "id": "subagent-1",
      "type": "subagent",
      "position": { "x": 800, "y": 240 },
      "data": {
        "label": "Researcher",
        "role": "Researcher",
        "taskInput": "item",
        "tools": ["web_search"],
        "maxIterations": 5
      }
    },
    {
      "id": "retriever-1",
      "type": "retriever",
      "position": { "x": 800, "y": 460 },
      "data": {
        "label": "Web Research",
        "knowledgeBase": "web",
        "topK": 5,
        "similarityThreshold": 0.7
      }
    },
    {
      "id": "join-1",
      "type": "join",
      "position": { "x": 1060, "y": 320 },
      "data": { "label": "Collect Findings", "mergeStrategy": "concat" }
    },
    {
      "id": "llm-1",
      "type": "llm",
      "position": { "x": 1320, "y": 320 },
      "data": {
        "label": "Synthesizer",
        "model": "gemini-2.5-flash",
        "systemPrompt": "Compose a complete, cited research report from the gathered findings.",
        "temperature": 0.4
      }
    },
    {
      "id": "evaluator-1",
      "type": "evaluator",
      "position": { "x": 1580, "y": 320 },
      "data": {
        "label": "Completeness Grader",
        "scoringPrompt": "Has every subtopic been covered with evidence? Reply 'complete' if yes; 'gaps' if more research is needed.",
        "scoreType": "pass_fail",
        "evalBranches": ["complete", "gaps"]
      }
    },
    {
      "id": "store-1",
      "type": "longTermStore",
      "position": { "x": 1840, "y": 220 },
      "data": {
        "label": "Persist Report",
        "namespace": "research_reports",
        "storeOperation": "write"
      }
    },
    {
      "id": "output-1",
      "type": "output",
      "position": { "x": 2100, "y": 220 },
      "data": { "label": "Report" }
