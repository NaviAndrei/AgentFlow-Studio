      "position": { "x": 1320, "y": 260 },
      "data": {
        "label": "Reducer",
        "model": "gemini-2.5-flash",
        "systemPrompt": "Combine the per-chunk summaries into one coherent overview.",
        "temperature": 0.3
      }
    },
    {
      "id": "output-1",
