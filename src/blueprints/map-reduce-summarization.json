      "position": { "x": 280, "y": 260 },
      "data": {
        "label": "Chunker",
        "model": "gemini-2.5-flash",
        "systemPrompt": "Split the document into self-contained sections and output them as a list under the state key 'chunks'.",
        "temperature": 0.2
      }
    },
    {
      "id": "map-1",
      "type": "map",
      "position": { "x": 540, "y": 260 },
      "data": {
