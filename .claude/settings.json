{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_start.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/inject_context.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/secret_scanner.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/bash_guard.py"
          },
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT_COMMAND\" | grep -qE 'rm -rf|git push --force|drop table' && exit 2 || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post_write_format.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/auto_format.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/auto_test.py"
          },
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -5"
          },
          {
            "type": "command",
            "command": "npx eslint $CLAUDE_FILE_PATH --max-warnings 0 2>&1 | head -10"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/on_stop_reminder.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/progress_guard.py"
          },
          {
            "type": "command",
            "command": "npm run test 2>&1 | tail -3"
          }
        ]
      }
    ]
  }
}